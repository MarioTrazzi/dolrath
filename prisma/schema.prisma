// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemType {
  SWORD
  AXE
  DAGGER
  STAFF
  BOW
  LIGHT_ARMOR
  MEDIUM_ARMOR
  HEAVY_ARMOR
  LIGHT_HELMET
  MEDIUM_HELMET
  HEAVY_HELMET
  LIGHT_GLOVES
  MEDIUM_GLOVES
  HEAVY_GLOVES
  LIGHT_BOOTS
  MEDIUM_BOOTS
  HEAVY_BOOTS
  RING
  NECKLACE
  SHIELD
  GAUNTLET
  ORB
  BELT
  PARRY_DAGGER
  TALISMAN
  CONSUMABLE
}

enum ConsumableSubtype {
  HEALTH_POTION
  MANA_POTION
  STAMINA_POTION
  ELIXIR
  STRENGTH_BUFF
  DEFENSE_BUFF
  AGILITY_BUFF
  INTELLIGENCE_BUFF
  REVIVE_POTION
  ANTIDOTE
  CURE_POISON
  TEMPORARY_BUFF
}

enum EquipmentSlotType {
  HELMET
  NECKLACE
  RING_1
  RING_2
  ARMOR
  WEAPON
  SHIELD
  GLOVES
  BOOTS
  BELT
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  walletAddress String?   @unique
  walletLinkedAt DateTime?
  walletLinkNonce String?
  walletLinkNonceExpiresAt DateTime?
  goldBalance   Int       @default(1000)
  // Slots do Baú Geral da conta (UserInventory). Começa em 50, expansível como o do personagem.
  globalInventorySlots Int  @default(50)

  // Optional on-chain claim flow (GOLD ERC-20): user accrues off-chain, claims on demand.
  goldClaimNonce Int       @default(0)
  goldClaimPendingAmount Int @default(0)
  goldClaimPendingNonce Int?
  goldClaimPendingDeadline DateTime?
  goldClaimPendingCreatedAt DateTime?
  goldClaimPendingTxHash String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  characters    Character[]
  inventory     UserInventory[]
  itemNfts      ItemNft[]
  dungeonRuns   DungeonRun[]
}

model UserInventory {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  item      Item     @relation(fields: [itemId], references: [id])
  itemId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

model Character {
  id            String          @id @default(cuid())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  name          String
  race          String
  class         String
  avatar        String?
  level         Int             @default(1)
  experience    Int             @default(0)
  attributes    Json?           @db.JsonB
  availablePoints Int           @default(0)
  gold          Int             @default(0)
  baseStats     Json?           @db.JsonB
  inventorySlots Int            @default(20)
  // Sistema de vida e morte
  hp            Int             @default(100)
  maxHp         Int             @default(100)
  // Sistema de mana
  mp            Int             @default(50)
  maxMp         Int             @default(50)
  isAlive       Boolean         @default(true)
  deathTimestamp DateTime?
  // Sistema de stamina
  stamina       Int             @default(100)
  maxStamina    Int             @default(100)
  // Âncora do regen passivo: marca o último gasto de stamina. Regen só começa
  // 15 min depois deste instante, então acumula +2 a cada 15 min (lazy, sem cron).
  staminaUpdatedAt DateTime     @default(now())

  // ⚒️ SISTEMA DE APRIMORAMENTO (estilo BDO)
  failstacks    Int             @default(0)
  
  // 🐉 SISTEMA DE TRANSFORMAÇÃO
  isTransformed     Boolean       @default(false)
  transformationType String?      // forma ATIVA no combate: 'dragon', 'wolf', 'bear', 'eagle', 'seventh_sense', 'celestial'
  transformationData Json?        @db.JsonB // { remainingTurns, cooldownTurns, originalStats }
  // Forma FIXA escolhida na criação (trava o metamorfo em 1 das 3; demais raças = única da raça)
  unlockedTransformation String? // 'dragon' | 'wolf' | 'bear' | 'eagle' | 'seventh_sense' | 'celestial'
  // Imagem da forma transformada (a "segunda NFT"), gerada a partir do avatar via gpt-image-1.
  // Para o metamorfo, guarda a forma padrão; o mapa completo fica em transformationImages.
  transformationImage    String?
  // Mapa de imagens por forma. Metamorfo: { wolf, bear, eagle }. Demais raças: 1 entrada.
  transformationImages   Json?
  
  equipment     CharacterEquipment[]
  inventory     CharacterInventory[]
  history       CharacterHistory[]
  dungeonRuns   DungeonRun[]

  // On-chain payment for creation (testnet: fixed DOL fee; mainnet: will be oracle-priced)
  creationTxHash String?         @unique
  creationPaidAt DateTime?

  // Character NFT (ERC-721)
  nftChainId     Int?
  nftContract    String?
  nftTokenId     BigInt?
  nftTokenUri    String?
  nftMintTxHash  String?         @unique
  nftMintedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
}

model Item {
  id          String    @id @default(cuid())
  name        String
  description String?
  image       String?
  type        ItemType
  subtype     ConsumableSubtype?
  level       Int       @default(1)
  goldPrice   Int       @default(100)
  stats       Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userInventory       UserInventory[]
  characterInventory  CharacterInventory[]
  equipment           CharacterEquipment[]
  history             CharacterHistory[]
  nfts                ItemNft[]
}

model ItemNft {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  item          Item     @relation(fields: [itemId], references: [id])
  itemId        String
  chainId       Int
  contract      String
  tokenId       BigInt
  paidGoldWei   String
  // ⚒️ Aprimoramento congelado no momento do mint (lazy-mint de item ganho).
  // 0 para itens de loja. Preserva a fidelidade (+N) no display do marketplace.
  enhancementLevel Int   @default(0)
  // Origem do mint: 'store' (compra) | 'lazy' (item ganho cunhado ao listar).
  mintSource    String   @default("store")
  purchaseTxHash String? @unique
  mintTxHash    String?  @unique
  mintedAt      DateTime @default(now())

  @@unique([chainId, contract, tokenId])
  @@index([userId])
  @@index([itemId])
}

model CharacterInventory {
  id          String    @id @default(cuid())
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId String
  item        Item      @relation(fields: [itemId], references: [id])
  itemId      String
  quantity    Int       @default(1)
  // ⚒️ Estado de aprimoramento por instância (linhas com enhancementLevel > 0 têm quantity 1)
  enhancementLevel Int  @default(0)
  durability       Int  @default(100)
  maxDurability    Int  @default(100)
  // 🔒 Trava temporária durante o lazy-mint (list-intent → list-confirm). Evita
  // que a peça seja vendida/consumida entre o voucher e o mint (duplicação).
  // Expira sozinha após alguns minutos se a listagem não completar.
  listingLockedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([characterId])
  @@index([itemId])
}

model CharacterEquipment {
  id          String           @id @default(cuid())
  character   Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId String
  item        Item            @relation(fields: [itemId], references: [id])
  itemId      String
  slot        EquipmentSlotType
  enhancementLevel Int        @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([characterId, slot])
  @@index([characterId])
  @@index([itemId])
}

enum ActivityType {
  ITEM_PURCHASE
  ITEM_GAINED
  ITEM_SOLD
  ITEM_CONSUMED
  ITEM_EQUIPPED
  ITEM_UNEQUIPPED
  XP_GAINED
  LEVEL_UP
  GOLD_GAINED
  GOLD_SPENT
  DUNGEON_COMPLETED
  CHARACTER_CREATED
  ATTRIBUTE_DISTRIBUTED
  INVENTORY_EXPANDED
  ITEM_ENHANCED
  ENHANCEMENT_FAILED
  ITEM_DESTROYED
  ITEM_REPAIRED
}

model CharacterHistory {
  id          String       @id @default(cuid())
  character   Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId String
  
  activityType ActivityType
  description  String
  details      Json?        // Para armazenar dados específicos da atividade
  
  // Campos opcionais para diferentes tipos de atividade
  itemId       String?
  item         Item?        @relation(fields: [itemId], references: [id])
  goldAmount   Int?
  xpAmount     Int?
  oldLevel     Int?
  newLevel     Int?
  
  createdAt    DateTime     @default(now())

  @@index([characterId])
  @@index([createdAt])
  @@index([activityType])
}

// 🏰 Sessão de masmorra SERVIDOR-AUTORITATIVA.
// O servidor é dono do RNG (d20, loot, stats do monstro), da progressão (cursor)
// e do crédito de gold/xp. O cliente só envia AÇÕES (avancei, venci o combate);
// nunca o valor da recompensa. Substitui o faucet client-authoritative que
// permitia mintar gold arbitrário via add-exploration-reward.
model DungeonRun {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId String
  dungeonId   String
  status      String    @default("active") // active | finished | defeated | abandoned
  cursor      Int       @default(0)         // índice do último nó RESOLVIDO (0 = entrada)
  nodeCount   Int                           // total de nós da trilha (inclui o boss)
  goldEarned  Int       @default(0)
  xpEarned    Int       @default(0)
  // Combate pendente: { nodeIdx, kind, lootRoll, monster } rolado pelo servidor,
  // aguardando o desfecho (win/lose) reportado pelo cliente.
  pending     Json?     @db.JsonB
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([characterId])
  @@index([characterId, status])
}

// Pagamento on-chain (DOL → tesouraria) consumido por uma regeração de imagem
// por IA (retrato base ou forma de transformação). O txHash único impede que a
// mesma transação pague mais de uma geração.
model AiGenPayment {
  id        String   @id @default(cuid())
  txHash    String   @unique
  userId    String
  purpose   String   // 'character-image-edit' | 'transformation-regen'
  amountDol String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Recarga de GOLD on-chain → saldo off-chain. O jogador transfere GOLD (ERC-20)
// para a tesouraria e o servidor credita o mesmo valor em Character.gold (a
// compra do item em si segue off-chain — comprar item-NFT direto na loja fica
// fora da lore; isso é papel do market). O txHash único impede que a mesma
// transação credite gold mais de uma vez (replay = gold grátis).
model GoldTopup {
  id          String   @id @default(cuid())
  txHash      String   @unique
  userId      String
  characterId String?
  amount      Int
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([characterId])
}
