# Configuração do servidor WebSocket
PORT=3001
SOCKET_PORT=3001

# URLs para produção - atualize conforme necessário
PRODUCTION_URL=https://dolrath.vercel.app
APP_URL=https://dolrath.vercel.app
SOCKET_URL_PRODUCTION=wss://dolrath.onrender.com

# Secret compartilhado com a API Next (/api/battle/rewards) — mesma var no Vercel.
# NÃO commitar o valor real: use .env local / dashboard do Render.
BATTLE_REWARDS_SECRET=

# Pot DOL da season PvP (default 1000)
PVP_SEASON_POT_DOL=1000

# URLs para desenvolvimento
DEV_URL=http://localhost:3000
SOCKET_URL_DEV=ws://localhost:3001
