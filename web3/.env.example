# RPCs
POLYGON_AMOY_RPC_URL=
POLYGON_MAINNET_RPC_URL=

# Deployer key (never commit a real key)
DEPLOYER_PRIVATE_KEY=

# Characters NFT (ERC-721) signer address (the server's signing wallet PUBLIC address)
NFT_SIGNER_ADDRESS=

# GOLD (ERC-20) signer address (the server's signing wallet PUBLIC address)
GOLD_SIGNER_ADDRESS=

# Optional overrides for deploy script
DOL_ADMIN=
DOL_MINTER=

# After deploying, set the token address here for scripts like mint
DOL_TOKEN_ADDRESS=

# After deploying, set the GOLD token address here for convenience
GOLD_CONTRACT_ADDRESS=

# After deploying, set the Items NFT address here for convenience
ITEM_NFT_CONTRACT_ADDRESS=

# Optional: baseURI used by DolrathItems.tokenURI().
# Example (prod): https://your-app.vercel.app/api/nft/item/metadata/
# Example (local): http://localhost:3000/api/nft/item/metadata/
ITEM_NFT_BASE_URI=

# After deploying, set the Item Market address here for convenience
ITEM_MARKET_CONTRACT_ADDRESS=

# Mint helper
DOL_MINT_TO=
DOL_MINT_AMOUNT=
