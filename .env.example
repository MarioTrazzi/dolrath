# Neon PostgreSQL Database
DATABASE_URL="sua_connection_string_aqui"

# NextAuth Configuration
NEXTAUTH_URL="https://seu-app.vercel.app"
NEXTAUTH_SECRET="chave_secreta_muito_longa_e_segura_aqui"

# OAuth Providers (opcional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# On-chain DOL (ERC-20)
# Used by /api/wallet/dol-balance to read the user's balance on Polygon Amoy (or mainnet)
DOL_TOKEN_ADDRESS=""
# Optional: if omitted, the app falls back to POLYGON_AMOY_RPC_URL / POLYGON_MAINNET_RPC_URL
DOL_RPC_URL=""

# Character creation payment (testnet: fixed DOL fee)
DOL_TREASURY_ADDRESS=""
CHARACTER_CREATION_COST_DOL="2"

# Client-side (optional). Needed only if you want the UI to initiate the ERC-20 transfer.
NEXT_PUBLIC_DOL_TOKEN_ADDRESS=""
NEXT_PUBLIC_DOL_TREASURY_ADDRESS=""
NEXT_PUBLIC_CHARACTER_CREATION_COST_DOL="2"

# Optional timeouts (ms) to avoid hanging on slow RPCs
DOL_RPC_TIMEOUT_MS="10000"
DOL_BALANCE_TIMEOUT_MS="12000"

# Characters NFT (ERC-721)
# Server-only: used to sign the mint intent (do NOT expose this to the client)
NFT_SIGNER_PRIVATE_KEY=""
# On-chain contract (after deploy)
CHARACTER_NFT_CONTRACT_ADDRESS=""
# Defaults to 80002 (Polygon Amoy)
CHARACTER_NFT_CHAIN_ID="80002"
# RPC for on-chain verification (optional; if empty, verification helper may fall back to other RPC envs)
CHARACTER_NFT_RPC_URL=""

# Example connection string format for Neon:
# DATABASE_URL="postgresql://username:password@ep-xxx.neon.tech/neondb?sslmode=require"
