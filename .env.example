# Neon PostgreSQL Database
DATABASE_URL="sua_connection_string_aqui"

# NextAuth Configuration
NEXTAUTH_URL="https://seu-app.vercel.app"
NEXTAUTH_SECRET="chave_secreta_muito_longa_e_segura_aqui"

# OAuth Providers (opcional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudinary (opcional)
# If you store only the publicId in DB (recommended), set CLOUDINARY_CLOUD_NAME.
# Example publicId: dolrath/items/sword_01
CLOUDINARY_CLOUD_NAME=""
# Optional: if you need it on the client for previews
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# On-chain DOL (ERC-20)
# Used by /api/wallet/dol-balance to read the user's balance on Polygon Amoy (or mainnet)
DOL_TOKEN_ADDRESS=""
# Optional: if omitted, the app falls back to POLYGON_AMOY_RPC_URL / POLYGON_MAINNET_RPC_URL
DOL_RPC_URL=""

# Character creation payment (testnet: fixed DOL fee)
DOL_TREASURY_ADDRESS=""
CHARACTER_CREATION_COST_DOL="2"

# Client-side (optional). Needed only if you want the UI to initiate the ERC-20 transfer.
NEXT_PUBLIC_DOL_TOKEN_ADDRESS=""
NEXT_PUBLIC_DOL_TREASURY_ADDRESS=""
NEXT_PUBLIC_CHARACTER_CREATION_COST_DOL="2"

# Optional timeouts (ms) to avoid hanging on slow RPCs
DOL_RPC_TIMEOUT_MS="10000"
DOL_BALANCE_TIMEOUT_MS="12000"

# Characters NFT (ERC-721)
# Server-only: used to sign the mint intent (do NOT expose this to the client)
NFT_SIGNER_PRIVATE_KEY=""
# On-chain contract (after deploy)
CHARACTER_NFT_CONTRACT_ADDRESS=""
# Defaults to 80002 (Polygon Amoy)
CHARACTER_NFT_CHAIN_ID="80002"
# RPC for on-chain verification (optional; if empty, verification helper may fall back to other RPC envs)
CHARACTER_NFT_RPC_URL=""

# GOLD (ERC-20) optional claim
# Users accrue GOLD off-chain (DB) and can claim on-chain on demand.
GOLD_CONTRACT_ADDRESS=""
GOLD_CHAIN_ID="80002"
# Optional: if omitted, the app falls back to POLYGON_AMOY_RPC_URL / POLYGON_MAINNET_RPC_URL
GOLD_RPC_URL=""
# Treasury address that receives on-chain GOLD payments (optional; if empty, falls back to DOL_TREASURY_ADDRESS)
GOLD_TREASURY_ADDRESS=""
# Server-only: used to sign EIP-712 claim vouchers (do NOT expose this to the client)
GOLD_SIGNER_PRIVATE_KEY=""

# Item NFTs (ERC-721)
ITEM_NFT_CONTRACT_ADDRESS=""
ITEM_NFT_CHAIN_ID="80002"
ITEM_NFT_RPC_URL=""
ITEM_NFT_RPC_TIMEOUT_MS="10000"

# Server-only signer for item mint intents
ITEM_NFT_SIGNER_PRIVATE_KEY=""

# Item Marketplace (escrow)
ITEM_MARKET_CONTRACT_ADDRESS=""
ITEM_MARKET_CHAIN_ID="80002"
ITEM_MARKET_RPC_URL=""
ITEM_MARKET_RPC_TIMEOUT_MS="10000"

# Character Marketplace (escrow de NFT de personagem, pago em DOL)
CHARACTER_MARKET_CONTRACT_ADDRESS=""
CHARACTER_MARKET_CHAIN_ID="80002"
CHARACTER_MARKET_RPC_URL=""
CHARACTER_MARKET_RPC_TIMEOUT_MS="10000"
# Optional: claim voucher validity window (seconds)
GOLD_CLAIM_DEADLINE_SECONDS="900"
# Optional timeouts (ms) to avoid hanging on slow RPCs
GOLD_RPC_TIMEOUT_MS="10000"

# Optional: timeout (ms) for fetching GOLD on-chain balance
GOLD_BALANCE_TIMEOUT_MS="12000"

# Optional: retries for confirming GOLD payment tx receipts (useful on unstable testnets)
GOLD_PAYMENT_RECEIPT_RETRIES="6"
GOLD_PAYMENT_RECEIPT_DELAY_MS="1000"

# Seed Endpoint Security
# Usado para autenticar requisições POST para /api/seed (execução de seeds via API)
SEED_SECRET="your-secure-seed-secret-here"

# Example connection string format for Neon:
# DATABASE_URL="postgresql://username:password@ep-xxx.neon.tech/neondb?sslmode=require"

# Geração de imagem da NFT do personagem (DALL·E 3 via OpenAI)
OPENAI_API_KEY="sk-proj-..."
# OPENAI_IMAGE_MODEL="dall-e-3"   # opcional (default: dall-e-3)
# OPENAI_IMAGE_SIZE="1024x1024"   # opcional (default: 1024x1024)

# Merge inteligente do prompt raça+classe + input do jogador (Claude via Anthropic)
# Sem esta chave, o servidor usa um merge determinístico (mantém o estilo travado).
ANTHROPIC_API_KEY="sk-ant-api03-..."
# ANTHROPIC_MODEL="claude-opus-4-8"   # opcional (default: claude-opus-4-8)
