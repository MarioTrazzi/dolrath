'use client'

import { useState } from 'react'
import { Character } from '@/types/game'
import { CharacterFactory } from '@/lib/characterFactory'
import { RACES, CLASSES, WEAPONS, ARMORS } from '@/lib/gameData'
import CharacterStatusManager from '@/components/CharacterStatusManager'
import Link from 'next/link'
import { ArrowLeft, User, Sword, Shield } from 'lucide-react'

export default function CharacterPage() {
  const [character, setCharacter] = useState<Character | null>(null)
  const [formData, setFormData] = useState({
    name: '',
    race: 'human',
    class: 'warrior',
    level: 1,
    weapon: 'iron_sword',
    armor: 'leather_armor'
  })

  const handleInputChange = (field: string, value: string | number) => {
    setFormData(prev => ({
      ...prev,
      [field]: value
    }))
  }

  const createCharacter = () => {
    try {
      const newCharacter = CharacterFactory.createCharacter(
        formData.name || 'Aventureiro',
        formData.race,
        formData.class,
        formData.level,
        formData.weapon,
        formData.armor
      )
      setCharacter(newCharacter)
    } catch (error) {
      console.error('Erro ao criar personagem:', error)
      alert('Erro ao criar personagem: ' + (error instanceof Error ? error.message : 'Erro desconhecido'))
    }
  }

  const resetForm = () => {
    setCharacter(null)
    setFormData({
      name: '',
      race: 'human',
      class: 'warrior',
      level: 1,
      weapon: 'iron_sword',
      armor: 'leather_armor'
    })
  }

  const getAvailableWeapons = () => {
    return WEAPONS.filter(weapon => {
      const characterClass = CLASSES.find(c => c.id === formData.class)
      return characterClass?.availableWeapons.includes(weapon.type)
    })
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-dolrath-dark via-gray-900 to-dolrath-dark">
      <div className="container mx-auto px-4 py-8">
        {/* Header */}
        <div className="flex items-center justify-between mb-8">
          <div className="flex items-center space-x-4">
            <Link href="/" className="btn-secondary">
              <ArrowLeft className="w-5 h-5" />
            </Link>
            <h1 className="text-3xl font-bold text-white">Criador de Personagens</h1>
          </div>
          <Link href="/combat" className="btn-primary">
            Ir para Combate
          </Link>
        </div>

        <div className="grid lg:grid-cols-2 gap-8">
          {/* Formulário */}
          <div className="card">
            <h2 className="text-2xl font-bold mb-6 flex items-center space-x-2">
              <User className="w-6 h-6" />
              <span>Criar Personagem</span>
            </h2>

            <div className="space-y-4">
              {/* Nome */}
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-2">
                  Nome do Personagem
                </label>
                <input
                  type="text"
                  value={formData.name}
                  onChange={(e) => handleInputChange('name', e.target.value)}
                  placeholder="Digite o nome..."
                  className="w-full px-3 py-2 bg-gray-700 text-white rounded-lg 
                           focus:outline-none focus:ring-2 focus:ring-dolrath-primary"
                />
              </div>

              {/* Raça */}
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-2">
                  Raça
                </label>
                <select
                  value={formData.race}
                  onChange={(e) => handleInputChange('race', e.target.value)}
                  className="w-full px-3 py-2 bg-gray-700 text-white rounded-lg 
                           focus:outline-none focus:ring-2 focus:ring-dolrath-primary"
                >
                  {RACES.map(race => (
                    <option key={race.id} value={race.id}>
                      {race.name} - {race.description}
                    </option>
                  ))}
                </select>
              </div>

              {/* Classe */}
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-2">
                  Classe
                </label>
                <select
                  value={formData.class}
                  onChange={(e) => handleInputChange('class', e.target.value)}
                  className="w-full px-3 py-2 bg-gray-700 text-white rounded-lg 
                           focus:outline-none focus:ring-2 focus:ring-dolrath-primary"
                >
                  {CLASSES.map(cls => (
                    <option key={cls.id} value={cls.id}>
                      {cls.name} - {cls.description}
                    </option>
                  ))}
                </select>
              </div>

              {/* Nível */}
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-2">
                  Nível (1-20)
                </label>
                <input
                  type="number"
                  min="1"
                  max="20"
                  value={formData.level}
                  onChange={(e) => handleInputChange('level', parseInt(e.target.value))}
                  className="w-full px-3 py-2 bg-gray-700 text-white rounded-lg 
                           focus:outline-none focus:ring-2 focus:ring-dolrath-primary"
                />
              </div>

              {/* Arma */}
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-2">
                  <Sword className="w-4 h-4 inline mr-1" />
                  Arma
                </label>
                <select
                  value={formData.weapon}
                  onChange={(e) => handleInputChange('weapon', e.target.value)}
                  className="w-full px-3 py-2 bg-gray-700 text-white rounded-lg 
                           focus:outline-none focus:ring-2 focus:ring-dolrath-primary"
                >
                  {getAvailableWeapons().map(weapon => (
                    <option key={weapon.id} value={weapon.id}>
                      {weapon.name} - {weapon.description}
                    </option>
                  ))}
                </select>
              </div>

              {/* Armadura */}
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-2">
                  <Shield className="w-4 h-4 inline mr-1" />
                  Armadura
                </label>
                <select
                  value={formData.armor}
                  onChange={(e) => handleInputChange('armor', e.target.value)}
                  className="w-full px-3 py-2 bg-gray-700 text-white rounded-lg 
                           focus:outline-none focus:ring-2 focus:ring-dolrath-primary"
                >
                  {ARMORS.map(armor => (
                    <option key={armor.id} value={armor.id}>
                      {armor.name} - {armor.description}
                    </option>
                  ))}
                </select>
              </div>

              {/* Botões */}
              <div className="flex space-x-4 pt-4">
                <button
                  onClick={createCharacter}
                  className="btn-primary flex-1"
                >
                  Criar Personagem
                </button>
                <button
                  onClick={resetForm}
                  className="btn-secondary"
                >
                  Limpar
                </button>
              </div>
            </div>
          </div>

          {/* Visualização do Personagem */}
          <div>
            {character ? (
              <div className="space-y-6">
                <CharacterStatusManager
                  character={character}
                  isCurrentTurn={false}
                  isPlayer={true}
                />
                
                <div className="card">
                  <h3 className="text-lg font-bold mb-4">Habilidades Raciais</h3>
                  <div className="space-y-2">
                    {character.race.abilities.map((ability, index) => (
                      <div key={index} className="flex items-center space-x-2">
                        <span className="w-2 h-2 bg-dolrath-primary rounded-full"></span>
                        <span className="text-sm">{ability}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <div className="card">
                  <h3 className="text-lg font-bold mb-4">Habilidades de Classe</h3>
                  <div className="space-y-2">
                    {character.class.abilities.map((ability, index) => (
                      <div key={index} className="flex items-center space-x-2">
                        <span className="w-2 h-2 bg-dolrath-secondary rounded-full"></span>
                        <span className="text-sm">{ability}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <div className="card">
                  <h3 className="text-lg font-bold mb-4">Poder de Combate</h3>
                  <div className="text-center">
                    <div className="text-3xl font-bold text-dolrath-accent">
                      {CharacterFactory.calculateCombatPower(character)}
                    </div>
                    <div className="text-sm text-gray-400">
                      Baseado em atributos, equipamentos e nível
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              <div className="card text-center py-12">
                <User className="w-16 h-16 mx-auto mb-4 text-gray-600" />
                <h3 className="text-xl font-bold mb-2">Nenhum Personagem Criado</h3>
                <p className="text-gray-400">
                  Preencha o formulário ao lado para criar seu personagem
                </p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  )
} 